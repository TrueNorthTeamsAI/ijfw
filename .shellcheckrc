shell=bash

# Default severity tiers (error / warning / info / style) are active. The
# optional-rules set (previously on via enable=all) was dominated by SC2250
# (${var} braces preference, 2185 hits) and SC2292 ([[ ]] vs [ ]  preference,
# 642 hits) -- pure style noise. Real bug checks (SC2154 unbound vars,
# SC2164 cd failure, SC2086 word-splitting) remain active.

# SC2312: "Consider invoking this command separately to avoid masking its
# return value" -- false positives on command substitution inside conditionals
# we rely on.
disable=SC2312

# SC2034: "X appears unused" -- heavy false-positive rate in our hook scripts
# where vars are declared for `set -u` safety, consumed via eval, or populated
# by sourced helpers shellcheck cannot statically trace.
disable=SC2034
